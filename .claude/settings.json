{
	"permissions": {
		"allow": [
			"Read(**)",
			"Edit(**)",
			"Write(**)",
			"Glob(**)",
			"Grep(**)",
			"WebFetch",
			"mcp__*",
			"Bash(*)"
		],
		"deny": [
			"Bash(rm -rf *)",
			"Bash(git push --force*)",
			"Bash(git push * --force*)",
			"Bash(git reset --hard*)",
			"Bash(git clean -f*)",
			"Bash(git checkout -- .)",
			"Bash(git restore .)",
			"Bash(git branch -D*)"
		]
	}
}
