{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"incremental": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	}
}
