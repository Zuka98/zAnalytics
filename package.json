{
	"name": "ts-monorepo-template",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.23.0",
	"engines": {
		"node": ">=20.x",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"build": "pnpm -r build",
		"format": "biome format . --write",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"type-check": "pnpm -r type-check",
		"dev": "pnpm --filter @zanalytics/api --filter @zanalytics/web -r dev",
		"dev:api": "pnpm --filter @zanalytics/api dev",
		"dev:web": "pnpm --filter @zanalytics/web dev",
		"db:generate": "dotenv -- pnpm --filter @zanalytics/db db:generate",
		"db:migrate": "pnpm --filter @zanalytics/db db:migrate",
		"db:studio": "dotenv -- pnpm --filter @zanalytics/db db:studio",
		"create:user": "dotenv -- tsx scripts/create-user.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.0",
		"dotenv-cli": "^11.0.0",
		"tsx": "^4.19.0",
		"typescript": "^5.9.0"
	},
	"dependencies": {
		"bcrypt-ts": "^8.0.1"
	}
}
