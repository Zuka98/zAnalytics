{
	"name": "ts-monorepo-template",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.23.0",
	"engines": {
		"node": ">=20.x",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"build": "pnpm -r build",
		"format": "biome format . --write",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"type-check": "pnpm -r type-check"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.0",
		"tsx": "^4.19.0",
		"typescript": "^5.9.0"
	}
}
